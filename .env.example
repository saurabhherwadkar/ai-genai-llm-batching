# .env.example
# Copy this file to .env and fill in your actual values.
# Environment variables override settings.yaml configuration.
# All variables are prefixed with LLM_BATCH_ to avoid conflicts.

# Required: Your LLM API authentication key
LLM_BATCH_API_KEY=your-api-key-here

# Optional: Override the API base URL (useful for local proxies or alternative providers)
# LLM_BATCH_API_BASE_URL=https://api.openai.com/v1

# Optional: Override batching parameters
# LLM_BATCH_BATCH_SIZE=5
# LLM_BATCH_MAX_CONCURRENT_REQUESTS=3

# Optional: Override logging level
# LLM_BATCH_LOG_LEVEL=DEBUG
